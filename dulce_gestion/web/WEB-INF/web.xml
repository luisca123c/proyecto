<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0"
         metadata-complete="true">

    <!-- ========== FILTROS ========== -->
    <filter>
        <filter-name>FiltroAutenticacion</filter-name>
        <filter-class>com.dulce_gestion.filters.FiltroAutenticacion</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>FiltroAutenticacion</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- ========== SERVLETS ========== -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.dulce_gestion.controllers.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DashboardServlet</servlet-name>
        <servlet-class>com.dulce_gestion.controllers.DashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DashboardServlet</servlet-name>
        <url-pattern>/dashboard</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.dulce_gestion.controllers.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <!-- NUEVO: EmpleadosServlet -->
    <servlet>
        <servlet-name>EmpleadosServlet</servlet-name>
        <servlet-class>com.dulce_gestion.controllers.EmpleadosServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EmpleadosServlet</servlet-name>
        <url-pattern>/empleados</url-pattern>
    </servlet-mapping>

    <!-- NuevoEmpleadoServlet -->
    <servlet>
        <servlet-name>NuevoEmpleadoServlet</servlet-name>
        <servlet-class>com.dulce_gestion.controllers.NuevoEmpleadoServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>NuevoEmpleadoServlet</servlet-name>
        <url-pattern>/empleados/nuevo</url-pattern>
    </servlet-mapping>

    <!-- EditarEmpleadoServlet -->
    <servlet>
        <servlet-name>EditarEmpleadoServlet</servlet-name>
        <servlet-class>com.dulce_gestion.controllers.EditarEmpleadoServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EditarEmpleadoServlet</servlet-name>
        <url-pattern>/empleados/editar</url-pattern>
    </servlet-mapping>

    <!-- EliminarEmpleadoServlet -->
    <servlet>
        <servlet-name>EliminarEmpleadoServlet</servlet-name>
        <servlet-class>com.dulce_gestion.controllers.EliminarEmpleadoServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EliminarEmpleadoServlet</servlet-name>
        <url-pattern>/empleados/eliminar</url-pattern>
    </servlet-mapping>

    <!-- ProductosServlet -->
    <servlet>
        <servlet-name>ProductosServlet</servlet-name>
        <servlet-class>com.dulce_gestion.controllers.ProductosServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProductosServlet</servlet-name>
        <url-pattern>/productos</url-pattern>
    </servlet-mapping>

    <!-- NuevoProductoServlet -->
    <servlet>
        <servlet-name>NuevoProductoServlet</servlet-name>
        <servlet-class>com.dulce_gestion.controllers.NuevoProductoServlet</servlet-class>
        <multipart-config>
            <max-file-size>5242880</max-file-size>
            <max-request-size>10485760</max-request-size>
            <file-size-threshold>1048576</file-size-threshold>
        </multipart-config>
    </servlet>
    <servlet-mapping>
        <servlet-name>NuevoProductoServlet</servlet-name>
        <url-pattern>/productos/nuevo</url-pattern>
    </servlet-mapping>

    <!-- EditarProductoServlet -->
    <servlet>
        <servlet-name>EditarProductoServlet</servlet-name>
        <servlet-class>com.dulce_gestion.controllers.EditarProductoServlet</servlet-class>
        <multipart-config>
            <max-file-size>5242880</max-file-size>
            <max-request-size>10485760</max-request-size>
            <file-size-threshold>1048576</file-size-threshold>
        </multipart-config>
    </servlet>
    <servlet-mapping>
        <servlet-name>EditarProductoServlet</servlet-name>
        <url-pattern>/productos/editar</url-pattern>
    </servlet-mapping>

    <!-- EliminarProductoServlet -->
    <servlet>
        <servlet-name>EliminarProductoServlet</servlet-name>
        <servlet-class>com.dulce_gestion.controllers.EliminarProductoServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EliminarProductoServlet</servlet-name>
        <url-pattern>/productos/eliminar</url-pattern>
    </servlet-mapping>
    <!-- ========== PERFIL ========== -->
    <servlet>
        <servlet-name>PerfilServlet</servlet-name>
        <servlet-class>com.dulce_gestion.controllers.PerfilServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PerfilServlet</servlet-name>
        <url-pattern>/perfil</url-pattern>

    <!-- VerPerfilServlet -->
    <servlet>
        <servlet-name>VerPerfilServlet</servlet-name>
        <servlet-class>com.dulce_gestion.controllers.VerPerfilServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>VerPerfilServlet</servlet-name>
        <url-pattern>/perfil/ver</url-pattern>
    </servlet-mapping>
    </servlet-mapping>

    <servlet>
        <servlet-name>EditarPerfilServlet</servlet-name>
        <servlet-class>com.dulce_gestion.controllers.EditarPerfilServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EditarPerfilServlet</servlet-name>
        <url-pattern>/perfil/editar</url-pattern>

    <!-- VerPerfilServlet -->
    <servlet>
        <servlet-name>VerPerfilServlet</servlet-name>
        <servlet-class>com.dulce_gestion.controllers.VerPerfilServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>VerPerfilServlet</servlet-name>
        <url-pattern>/perfil/ver</url-pattern>
    </servlet-mapping>
    </servlet-mapping>

    

    <!-- GastosServlet -->
    <servlet>
        <servlet-name>GastosServlet</servlet-name>
        <servlet-class>com.dulce_gestion.controllers.GastosServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>GastosServlet</servlet-name>
        <url-pattern>/gastos</url-pattern>
    </servlet-mapping>

    <!-- GananciasServlet -->
    <servlet>
        <servlet-name>GananciasServlet</servlet-name>
        <servlet-class>com.dulce_gestion.controllers.GananciasServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>GananciasServlet</servlet-name>
        <url-pattern>/ganancias</url-pattern>
    </servlet-mapping>

    <!-- VentasServlet -->
    <servlet>
        <servlet-name>VentasServlet</servlet-name>
        <servlet-class>com.dulce_gestion.controllers.VentasServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>VentasServlet</servlet-name>
        <url-pattern>/ventas</url-pattern>
    </servlet-mapping>

    <!-- ========== SESIÓN ========== -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

</web-app>
